# Neon Postgres
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Auth.js
AUTH_SECRET=generate-with-openssl-rand-base64-32

# Pusher (realtime sync)
PUSHER_APP_ID=your-app-id
NEXT_PUBLIC_PUSHER_KEY=your-key
PUSHER_SECRET=your-secret
NEXT_PUBLIC_PUSHER_CLUSTER=eu

# SMTP / Gmail (email invites — optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=Cartlo <your-email@gmail.com>

# App URL (used in email links, auto-detected on Vercel)
NEXT_PUBLIC_APP_URL=https://cartlo.vercel.app

# OpenAI API (embeddings for smart product categorization — optional)
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key
